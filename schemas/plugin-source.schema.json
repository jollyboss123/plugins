{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "plugin-source.schema.json",
  "title": "Canonical Plugin Source Manifest",
  "type": "object",
  "required": [
    "name",
    "version",
    "description",
    "scope",
    "license",
    "workflows",
    "parityMode",
    "invocationPolicy",
    "install"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": {
      "type": "string"
    },
    "scope": {
      "type": "string",
      "pattern": "^@[a-z0-9-]+$"
    },
    "license": {
      "type": "string"
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      }
    },
    "parityMode": {
      "type": "string",
      "enum": [
        "behavioral"
      ]
    },
    "invocationPolicy": {
      "type": "object",
      "required": [
        "doWorkRequiresPrdToPlan",
        "prdToPlanExplicit",
        "writeAPrdExplicit"
      ],
      "properties": {
        "doWorkRequiresPrdToPlan": {
          "type": "boolean"
        },
        "prdToPlanExplicit": {
          "type": "boolean"
        },
        "writeAPrdExplicit": {
          "type": "boolean"
        }
      }
    },
    "install": {
      "type": "object",
      "required": [
        "safePostinstallDefault",
        "globalOptInEnv"
      ],
      "properties": {
        "safePostinstallDefault": {
          "type": "boolean"
        },
        "globalOptInEnv": {
          "type": "string"
        }
      }
    }
  }
}
